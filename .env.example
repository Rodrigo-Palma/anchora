# anchora configuration (all optional; sensible local-first defaults apply).
# Copy to .env and adjust. Variables are prefixed ANCHORA_.

# Local Ollama endpoint used for embeddings and generation.
ANCHORA_OLLAMA_BASE_URL=http://localhost:11434

# Generation and embedding models (must be pulled in Ollama).
ANCHORA_GEN_MODEL=qwen3:32b
ANCHORA_EMBED_MODEL=nomic-embed-text

# Embedding provider: "ollama" (local model) or "hash" (deterministic, offline).
ANCHORA_EMBED_PROVIDER=ollama

# Retrieval / eval knobs.
ANCHORA_TOP_K=4
ANCHORA_FAITHFULNESS_THRESHOLD=0.70

# Optional API-key gate for the serving endpoints (empty = open dev mode).
ANCHORA_API_KEY=
